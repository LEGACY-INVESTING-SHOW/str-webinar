{
  "version": 2,
  "public": true,
  "headers": [
    {
      "source": "/str/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31556952, immutable"
        }
      ]
    },
    {
      "source": "/stories/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31556952, immutable"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31556952, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/v1/index.html"
    },
    {
      "source": "/registered",
      "destination": "/registered.html"
    },
    {
      "source": "/arbitrage",
      "destination": "/arbitrage.html"
    },
    {
      "source": "/airbnb-arbitrage",
      "destination": "/airbnb-arbitrage.html"
    },
    {
      "source": "/ownership",
      "destination": "/ownership.html"
    },
    {
      "source": "/ownership-breakdown",
      "destination": "/ownership-breakdown.html"
    },
    {
      "source": "/sstr",
      "destination": "/sstr.html"
    },
    {
      "source": "/advertorial11",
      "destination": "/advertorial11.html"
    },
    {
      "source": "/str-arbitrage",
      "destination": "/str-arbitrage.html"
    },
    {
      "source": "/str-ownership",
      "destination": "/str-ownership.html"
    },
    {
      "source": "/pre-call",
      "destination": "/pre-call.html"
    },
    {
      "source": "/slides",
      "destination": "/slides.html"
    }
  ]
}
